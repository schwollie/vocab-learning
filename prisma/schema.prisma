// This is your Prisma schema file

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// App Specific Schema

model User {
  id            String    @id @default(cuid()) // Can be used for Clerk User ID
  email         String?   @unique
  
  // App specific
  vocabSets     VocabSet[]
  folders       Folder[]
  userSettings  UserSettings?
  studySessions StudySession[]
}


model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoplayAudio   Boolean  @default(true)
  preferredVoice  String?
  primaryLanguage String?  @default("en-US") // legacy mirror of defaultSideBLanguage
  defaultSideALanguage String @default("es-ES")
  defaultSideBLanguage String @default("en-US")
  defaultStudyMode String  @default("due")
  defaultDirection String  @default("term_to_definition")
  defaultAutoplayMode String @default("both")
  showReviewIntervalPopup Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Folder {
  id          String     @id @default(cuid())
  name        String
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Folder?    @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]   @relation("FolderHierarchy")
  vocabSets   VocabSet[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId, parentId])
  @@unique([userId, name, parentId])
}

model VocabSet {
  id          String      @id @default(cuid())
  title       String
  description String?
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      Folder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  items       VocabItem[]
  isPublic    Boolean     @default(false)
  shareId     String      @unique @default(uuid())
  sideALabel  String      @default("Side A")
  sideBLabel  String      @default("Side B")
  sideALanguage String    @default("es-ES")
  sideBLanguage String    @default("en-US")
  learningSide String     @default("A") // A or B
  autoplayModeOverride String @default("default") // default|off|A|B|both
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model VocabItem {
  id          String      @id @default(cuid())
  setId       String
  set         VocabSet    @relation(fields: [setId], references: [id], onDelete: Cascade)
  term        String
  definition  String
  
  // FSRS Specific fields
  stability   Float       @default(2.0)
  difficulty  Float       @default(5.0)
  elapsedDays Int         @default(0)
  scheduledDays Int       @default(0)
  reps        Int         @default(0)
  state       Int         @default(0) // 0: New, 1: Learning, 2: Review, 3: Relearning
  lastReview  DateTime?
  nextReview  DateTime?   // For easily querying what's due
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  reviewLogs  ReviewLog[]
}

model ReviewLog {
  id          String    @id @default(cuid())
  itemId      String
  item        VocabItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  rating      Int       // 1: Again, 2: Hard, 3: Good, 4: Easy
  state       Int
  due         DateTime
  stability   Float
  difficulty  Float
  elapsedDays Int
  lastElapsedDays Int
  scheduledDays Int
  review      DateTime  @default(now())
}

model StudySession {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopeType         String
  scopeId           String
  includeSubfolders Boolean  @default(false)
  mode              String
  direction         String
  isLearning        Boolean  @default(true)
  queueJson         Json
  cursor            Int      @default(0)
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, scopeType, scopeId])
  @@index([userId, updatedAt])
}