// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth Next.js Auth Schema
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // App specific
  vocabSets     VocabSet[]
  folders       Folder[]
  userSettings  UserSettings?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App Specific Schema

model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoplayAudio   Boolean  @default(true)
  preferredVoice  String?
  primaryLanguage String?  @default("en-US")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Folder {
  id          String     @id @default(cuid())
  name        String
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabSets   VocabSet[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model VocabSet {
  id          String      @id @default(cuid())
  title       String
  description String?
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      Folder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  items       VocabItem[]
  isPublic    Boolean     @default(false)
  shareId     String      @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model VocabItem {
  id          String      @id @default(cuid())
  setId       String
  set         VocabSet    @relation(fields: [setId], references: [id], onDelete: Cascade)
  term        String
  definition  String
  
  // FSRS Specific fields
  stability   Float       @default(2.0)
  difficulty  Float       @default(5.0)
  elapsedDays Int         @default(0)
  scheduledDays Int       @default(0)
  reps        Int         @default(0)
  state       Int         @default(0) // 0: New, 1: Learning, 2: Review, 3: Relearning
  lastReview  DateTime?
  nextReview  DateTime?   // For easily querying what's due
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  reviewLogs  ReviewLog[]
}

model ReviewLog {
  id          String    @id @default(cuid())
  itemId      String
  item        VocabItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  rating      Int       // 1: Again, 2: Hard, 3: Good, 4: Easy
  state       Int
  due         DateTime
  stability   Float
  difficulty  Float
  elapsedDays Int
  lastElapsedDays Int
  scheduledDays Int
  review      DateTime  @default(now())
}