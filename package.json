{
  "name": "vocab-learning",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "packageManager": "npm@11.13.0",
  "overrides": {
    "postcss": "8.5.14"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "standalone": "next build --standalone",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run test && npm run typecheck && npm run build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.9.15",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "fsrs.js": "^1.2.2",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
