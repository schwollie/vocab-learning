# Copy to `.env` and fill in secrets. Compose loads `.env`.

# -----------------------------------------------------------------------------
# PostgreSQL — use one strong password everywhere (no special URL chars unless encoded)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_long_random_password
POSTGRES_DB=vocab_learning
DATABASE_URL="postgresql://postgres:change_me_to_a_long_random_password@db:5432/vocab_learning?schema=public"

# One-time password sync after changing POSTGRES_PASSWORD (keeps existing data):
#   docker exec vocab-db psql -U postgres -d vocab_learning \
#     -c "ALTER USER postgres WITH PASSWORD 'your_new_password';"

# -----------------------------------------------------------------------------
# Clerk production keys + URLs (Dashboard: allow https://vocab.YOUR_PUBLIC_DOMAIN)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# -----------------------------------------------------------------------------
# Public URLs (TLS via ~/reverse-proxy Caddy)
# sslip.io: 159.195.38.197 → PUBLIC_DOMAIN=159-195-38-197.sslip.io
# App is served at https://vocab.${PUBLIC_DOMAIN} (apex redirects to subdomain)
PUBLIC_DOMAIN=159-195-38-197.sslip.io

# Optional: allow pk_test_* on a public server while testing
# ALLOW_CLERK_DEV_KEYS=true

# -----------------------------------------------------------------------------
# Gemini (lexicon / dictionary panel)
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-3.1-flash-lite
